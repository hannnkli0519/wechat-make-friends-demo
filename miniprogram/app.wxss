/** app.wxss **/

/* 全局样式 */
page {
  background: #f6f6f6;
  box-sizing: border-box;
}

button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

/* 颜色变量 */
page {
  --color-primary: #F5B4BC;
  --color-primary-light: #FEF0F2;
  --color-primary-dark: #E89DA6;
  --color-text-main: #2D3748;
  --color-text-sub: #718096;
  --color-text-placeholder: #A0AEC0;
  --color-bg: #F6F6F6;
  --color-bg-white: #FFFFFF;
  --color-border: #E2E8F0;
  --color-empty: #CBD5E0;
  --color-danger: #F5B4BC;
  --color-success: #48BB78;
  --color-blue: #4299E1;
}

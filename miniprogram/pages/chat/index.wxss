/* pages/chat/index.wxss */
.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f6f6f6;
  box-sizing: border-box;
}

/* Header */
.chat-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 88rpx;
  padding: 0 40rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e2e8f0;
  box-sizing: border-box;
}

.chat-header-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.chat-header-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #2d3748;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Chat Content */
.chat-content {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
  box-sizing: border-box;
}

.chat-message-item {
  margin-bottom: 24rpx;
}

.chat-message-other {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

.chat-message-self {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: flex-end;
}

.chat-message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.chat-message-bubble {
  max-width: 70%;
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.chat-message-time {
  font-size: 20rpx;
  color: #a0aec0;
  margin-top: 8rpx;
  align-self: flex-end;
}

.chat-message-bubble-right .chat-message-time {
  color: rgba(255, 255, 255, 0.8);
}

.chat-message-bubble-left {
  background: #ffffff;
  margin-left: 16rpx;
  border-top-left-radius: 4rpx;
}

.chat-message-bubble-right {
  background: #f5b4bc;
  margin-right: 16rpx;
  border-top-right-radius: 4rpx;
}

.chat-message-text {
  font-size: 28rpx;
  color: #2d3748;
  line-height: 1.5;
  word-break: break-all;
}

.chat-message-bubble-right .chat-message-text {
  color: #ffffff;
}

/* Footer */
.chat-footer {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-top: 1rpx solid #e2e8f0;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  gap: 16rpx;
  box-sizing: border-box;
  z-index: 1000;
}

/* 当键盘弹出时，减少底部间距，让输入框紧贴键盘 */
.chat-footer.keyboard-up {
  padding-bottom: 20rpx;
}

.chat-input-wrap {
  flex: 1;
  background: #f6f6f6;
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  box-sizing: border-box;
}

.chat-input {
  font-size: 28rpx;
  color: #2d3748;
  width: 100%;
}

.chat-input-placeholder {
  color: #a0aec0;
}

.chat-send-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chat-send-btn.active {
  background: #f5b4bc;
}

.send-icon {
  font-size: 36rpx;
  color: #ffffff;
  transform: rotate(-45deg);
}

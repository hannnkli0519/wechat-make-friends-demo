/* pages/onboarding/index.wxss */
.container {
  height: 100vh;
  width: 100%;
  background: #ffffff;
}

.swiper {
  height: 100%;
  width: 100%;
}

.onboarding-page {
  height: 100%;
  width: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  position: relative;
}

.content-box {
  height: 100%; /* 明确高度 */
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 60rpx;
  padding-bottom: 180rpx; /* 为底部的固定按钮留出空间 */
  box-sizing: border-box;
  text-align: center;
}

.icon-wrap {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #2d3748;
  margin-bottom: 30rpx;
}

.desc {
  font-size: 30rpx;
  color: #718096;
  line-height: 1.6;
}

.page-title {
  font-size: 44rpx; /* 调大页面标题 */
  font-weight: bold;
  color: #2d3748;
  margin-bottom: 48rpx;
  display: block;
}

/* Form Styles - Reusing profile-edit styles */
.form-content {
  height: 100%;
  padding: 40rpx;
  padding-bottom: 240rpx; /* 增加底部间距，确保内容不被固定按钮遮挡 */
  box-sizing: border-box;
  background: #f6f6f6;
}

.edit-section {
  margin-bottom: 40rpx; /* 增加间距使布局更透气 */
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  font-size: 30rpx; /* 略微调大标题 */
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 24rpx;
  display: block;
}

.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.required::after {
  content: "*";
  color: #f5b4bc;
  margin-left: 8rpx;
}

.optional-tag {
  font-size: 24rpx;
  color: #a0aec0;
  font-weight: normal;
}

.photos-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item {
  width: calc((100% - 40rpx) / 3);
  aspect-ratio: 1/1;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  box-sizing: border-box;
}

.photo-image {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  z-index: 10;
}

.photo-add {
  background: #ffffff;
  border: 2rpx dashed #cbd5e0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.photo-add-icon {
  font-size: 48rpx;
  color: #a0aec0;
}

.form-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #ffffff;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

.form-item:first-of-type {
  border-radius: 16rpx 16rpx 0 0;
}

.form-item:last-of-type {
  border-radius: 0 0 16rpx 16rpx;
  border-bottom: none;
}

.form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #718096;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #2d3748;
  text-align: right;
  padding-left: 20rpx;
}

.bio-input {
  width: 100%;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #2d3748;
  min-height: 200rpx;
  box-sizing: border-box;
}

.interests-wrap {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  box-sizing: border-box;
}

.interest-tag {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #718096;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
}

.interest-tag.selected {
  background: #f5b4bc;
  color: #ffffff;
  border-color: #f5b4bc;
}

.footer {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 40rpx 60rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #e2e8f0;
}

.btn-primary {
  width: 100%;
  background: #f5b4bc;
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
  height: 100rpx;
  line-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary.disabled {
  background: #fbd7db;
  color: rgba(255, 255, 255, 0.8);
}

<!-- pages/home/index.wxml -->
<view class="home-page">
  <view class="header">
    <text class="header-title">推荐</text>
    <view class="filter-btn" bindtap="onFilterTap">
      <text class="filter-icon">☰</text>
    </view>
  </view>

  <view class="content">
    <block wx:if="{{userList.length > 0}}">
      <view class="user-card" wx:for="{{userList}}" wx:key="_id" wx:for-item="user" wx:for-index="index">
        <view class="user-card-image">
          <swiper class="user-swiper" indicator-dots="{{(user.photos && user.photos.length > 1)}}" indicator-active-color="#f5b4bc" indicator-color="rgba(255, 255, 255, 0.6)" circular bindchange="onSwiperChange" data-userindex="{{index}}">
            <block wx:if="{{user.photos && user.photos.length > 0}}">
              <swiper-item wx:for="{{user.photos}}" wx:for-item="photo" wx:key="*this">
                <image class="user-photo" src="{{photo}}" mode="aspectFill" />
              </swiper-item>
            </block>
            <block wx:else>
              <swiper-item>
                <image class="user-photo" src="{{user.avatar}}" mode="aspectFill" />
              </swiper-item>
            </block>
          </swiper>
          <!-- 图片索引提示 -->
          <view class="photo-badge" wx:if="{{user.photos && user.photos.length > 1}}">
            <text class="photo-badge-text">{{ (user.currentPhotoIndex || 0) + 1 }}/{{ user.photos.length }}</text>
          </view>
          <view class="user-card-overlay">
            <view class="user-card-info">
              <text class="user-name">{{user.name}}</text>
              <text class="user-meta">{{user.age}}岁 · {{user.city}}</text>
              <view class="user-tags">
                <view class="user-tag" wx:for="{{user.interests}}" wx:for-item="interest" wx:key="*this">
                  {{interest}}
                </view>
              </view>
            </view>
          </view>
        </view>
        <view class="user-card-actions">
          <view class="btn-skip" bindtap="onSkipTap" data-id="{{user._id}}">
            <text class="btn-skip-text">✕ 跳过</text>
          </view>
          <view class="btn-like" bindtap="onLikeTap" data-id="{{user._id}}">
            <text class="btn-like-text">♡ 喜欢</text>
          </view>
        </view>
      </view>
    </block>

    <block wx:if="{{userList.length === 0}}">
      <view class="empty-state">
        <view class="empty-icon">
          <text class="empty-icon-text">♡</text>
        </view>
        <text class="empty-title">暂无推荐</text>
        <text class="empty-desc">稍后再来看看吧</text>
      </view>
    </block>
  </view>
</view>
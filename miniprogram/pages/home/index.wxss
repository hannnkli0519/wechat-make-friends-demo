/* pages/home/index.wxss */
.home-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f6f6f6;
}

.header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e2e8f0;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2d3748;
}

.filter-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #edf2f7;
}

.filter-icon {
  font-size: 32rpx;
  color: #718096;
}

.content {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 24rpx 40rpx;
}

.user-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.user-card-image {
  position: relative;
  width: 100%;
  height: 600rpx;
}

.user-avatar {
  width: 100%;
  height: 100%;
}

.user-card-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.5));
}

.user-card-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.user-meta {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 16rpx;
}

.user-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.user-tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 20rpx;
  background: rgba(245, 180, 188, 0.9);
  color: #ffffff;
  border-radius: 30rpx;
  font-size: 22rpx;
}

.user-card-actions {
  display: flex;
  flex-direction: row;
  padding: 20rpx 24rpx;
  gap: 20rpx;
}

.btn-skip {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: #f6f6f6;
  border-radius: 50rpx;
  border: 1rpx solid #e2e8f0;
}

.btn-skip-text {
  font-size: 28rpx;
  color: #718096;
}

.btn-like {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: #f5b4bc;
  border-radius: 50rpx;
}

.btn-like-text {
  font-size: 28rpx;
  color: #ffffff;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #edf2f7;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon-text {
  font-size: 64rpx;
  color: #cbd5e0;
}

.empty-title {
  font-size: 36rpx;
  color: #2d3748;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #a0aec0;
}

/* pages/profile-edit/index.wxss */
.edit-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f6f6f6;
}

.edit-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  height: 88rpx;
  padding: 0 40rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e2e8f0;
}

.edit-header-title {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: #2d3748;
}

.save-btn {
  width: 64rpx;
  text-align: right;
  font-size: 28rpx;
  color: #f5b4bc;
}

.edit-content {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* Section */
.edit-section {
  margin-bottom: 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d3748;
  margin-bottom: 20rpx;
  display: block;
}

/* Photos */
.photos-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 20rpx;
}

.photo-item {
  width: calc((100% - 40rpx) / 3);
  aspect-ratio: 1/1;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  box-sizing: border-box;
}

.photo-image {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  z-index: 10;
}

.photo-add {
  background: #ffffff;
  border: 2rpx dashed #cbd5e0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.photo-add-icon {
  font-size: 48rpx;
  color: #a0aec0;
  margin-bottom: 8rpx;
}

.photo-add-text {
  font-size: 22rpx;
  color: #a0aec0;
}

/* Form */
.form-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #ffffff;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

.form-item:first-of-type {
  border-radius: 16rpx 16rpx 0 0;
}

.form-item:last-of-type {
  border-radius: 0 0 16rpx 16rpx;
  border-bottom: none;
}

.form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #718096;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #2d3748;
  text-align: right;
  padding-left: 20rpx;
}

/* Bio */
.bio-input {
  width: 100%;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #2d3748;
  min-height: 200rpx;
  box-sizing: border-box;
}

/* Interests */
.interests-wrap {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
  box-sizing: border-box;
}

.interest-tag {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #718096;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
}

.interest-tag.selected {
  background: #f5b4bc;
  color: #ffffff;
  border-color: #f5b4bc;
}
